# Git LFS tracking patterns (activate after: brew install git-lfs && git lfs install)
# *.pdf filter=lfs diff=lfs merge=lfs -text
# *.pages filter=lfs diff=lfs merge=lfs -text
# *.csv filter=lfs diff=lfs merge=lfs -text
# *.jsonl filter=lfs diff=lfs merge=lfs -text

# Ensure consistent line endings for source files
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Binary files
*.pdf binary
*.pages binary
*.zip binary
*.png binary
*.jpg binary
*.webp binary
