{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "A2_BRAIN_UPDATE_PACKET_STAGE2_v1.schema.json",
  "title": "A2_BRAIN_UPDATE_PACKET_STAGE2_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "packet_id",
    "source_job_id",
    "invariants_learned",
    "unresolved_conflicts",
    "classical_residue_candidates",
    "next_actions"
  ],
  "properties": {
    "schema": {
      "const": "A2_BRAIN_UPDATE_PACKET_STAGE2_v1"
    },
    "packet_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]{8,160}$"
    },
    "source_job_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_]{8,160}$"
    },
    "source_artifact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "invariants_learned": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "invariant_id",
          "statement"
        ],
        "properties": {
          "invariant_id": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{4,120}$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "source_locator": {
            "type": "string"
          }
        }
      }
    },
    "unresolved_conflicts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "conflict_id",
          "description"
        ],
        "properties": {
          "conflict_id": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{4,120}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "source_locator": {
            "type": "string"
          }
        }
      }
    },
    "classical_residue_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "residue_id",
          "class",
          "description"
        ],
        "properties": {
          "residue_id": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{4,120}$"
          },
          "class": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{4,120}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "template_upgrade_recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

