{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "AUDIT_PROJECT_SAVE_DOC_REPORT_v1.schema.json",
  "title": "AUDIT_PROJECT_SAVE_DOC_REPORT_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "doc_path", "checks", "errors"],
  "properties": {
    "schema": {
      "const": "AUDIT_PROJECT_SAVE_DOC_REPORT_v1"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "doc_path": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "status", "detail"],
        "properties": {
          "check_id": {"type": "string"},
          "status": {"type": "string", "enum": ["PASS", "FAIL"]},
          "detail": {"type": "string"}
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
