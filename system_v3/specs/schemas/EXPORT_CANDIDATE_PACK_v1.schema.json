{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "EXPORT_CANDIDATE_PACK_v1.schema.json",
  "title": "EXPORT_CANDIDATE_PACK_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "pack_id", "created_utc", "candidate_items", "required_dependencies", "negative_pressure", "source_pointers"],
  "properties": {
    "schema": { "const": "EXPORT_CANDIDATE_PACK_v1" },
    "pack_id": { "type": "string" },
    "created_utc": { "type": "string" },
    "candidate_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "kernel_anchor", "anchor_type", "source_term", "source_pointers"],
        "properties": {
          "candidate_id": { "type": "string" },
          "kernel_anchor": { "type": "string" },
          "anchor_type": { "type": "string", "enum": ["TERM", "SPEC_ID"] },
          "source_term": { "type": "string" },
          "source_pointers": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "required_dependencies": { "type": "array", "items": { "type": "string" } },
    "negative_pressure": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pressure_id", "text", "source_pointer"],
        "properties": {
          "pressure_id": { "type": "string" },
          "text": { "type": "string" },
          "source_pointer": { "type": "string" }
        }
      }
    },
    "source_pointers": { "type": "array", "items": { "type": "string" } }
  }
}
