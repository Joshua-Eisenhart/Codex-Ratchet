{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "FUEL_DIGEST_v1.schema.json",
  "title": "FUEL_DIGEST_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "digest_id", "created_utc", "source_list", "extracted_claims", "kernel_candidate_suggestions", "overlay_mapping_suggestions", "source_pointers"],
  "properties": {
    "schema": { "const": "FUEL_DIGEST_v1" },
    "digest_id": { "type": "string" },
    "created_utc": { "type": "string" },
    "source_list": { "type": "array", "items": { "type": "string" } },
    "extracted_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim_id", "text", "source_pointer"],
        "properties": {
          "claim_id": { "type": "string" },
          "text": { "type": "string" },
          "source_pointer": { "type": "string" }
        }
      }
    },
    "kernel_candidate_suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "kernel_candidate", "candidate_type", "source_pointer"],
        "properties": {
          "candidate_id": { "type": "string" },
          "kernel_candidate": { "type": "string" },
          "candidate_type": { "type": "string", "enum": ["TERM", "SPEC_ID"] },
          "source_pointer": { "type": "string" }
        }
      }
    },
    "overlay_mapping_suggestions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["mapping_id", "source_term", "kernel_anchor_candidate", "anchor_type", "source_pointer"],
        "properties": {
          "mapping_id": { "type": "string" },
          "source_term": { "type": "string" },
          "kernel_anchor_candidate": { "type": "string" },
          "anchor_type": { "type": "string", "enum": ["TERM", "SPEC_ID"] },
          "source_pointer": { "type": "string" }
        }
      }
    },
    "source_pointers": { "type": "array", "items": { "type": "string" } }
  }
}
