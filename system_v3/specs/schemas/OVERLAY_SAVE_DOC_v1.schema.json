{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "OVERLAY_SAVE_DOC_v1.schema.json",
  "title": "OVERLAY_SAVE_DOC_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "overlay_save_id", "created_utc", "fuel_digests", "rosetta_maps", "provenance", "integrity_hashes"],
  "properties": {
    "schema": { "const": "OVERLAY_SAVE_DOC_v1" },
    "overlay_save_id": { "type": "string" },
    "created_utc": { "type": "string" },
    "fuel_digests": { "type": "array", "items": { "$ref": "#/$defs/fileRef" } },
    "rosetta_maps": { "type": "array", "items": { "$ref": "#/$defs/fileRef" } },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_pointers"],
      "properties": {
        "source_pointers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "integrity_hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fuel_digest_count", "rosetta_map_count"],
      "properties": {
        "fuel_digest_count": { "type": "integer", "minimum": 0 },
        "rosetta_map_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "fileRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string" },
        "digest_id": { "type": "string" },
        "map_id": { "type": "string" }
      }
    }
  }
}
