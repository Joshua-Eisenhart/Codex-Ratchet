{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "TAPE_SUMMARY_REPORT_v1.schema.json",
  "title": "TAPE_SUMMARY_REPORT_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "run_dir", "status", "export_tape", "campaign_tape", "missing_pair_anomalies"],
  "properties": {
    "schema": {
      "const": "TAPE_SUMMARY_REPORT_v1"
    },
    "run_dir": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "export_tape": {
      "$ref": "#/$defs/tapeSummary"
    },
    "campaign_tape": {
      "$ref": "#/$defs/tapeSummary"
    },
    "missing_pair_anomalies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "seq", "export_id"],
        "properties": {
          "kind": {"type": "string"},
          "seq": {"type": "integer", "minimum": 0},
          "export_id": {"type": "string"}
        }
      }
    }
  },
  "$defs": {
    "tapeSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_count",
        "first_seq",
        "last_seq",
        "first_export_id",
        "last_export_id",
        "unique_export_id_count",
        "digest_sha256",
        "path",
        "file_sha256"
      ],
      "properties": {
        "entry_count": {"type": "integer", "minimum": 0},
        "first_seq": {"type": "integer", "minimum": 0},
        "last_seq": {"type": "integer", "minimum": 0},
        "first_export_id": {"type": "string"},
        "last_export_id": {"type": "string"},
        "unique_export_id_count": {"type": "integer", "minimum": 0},
        "digest_sha256": {"type": "string"},
        "path": {"type": "string"},
        "file_sha256": {"type": "string"}
      }
    }
  }
}
