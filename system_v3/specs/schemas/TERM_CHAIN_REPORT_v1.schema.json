{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "TERM_CHAIN_REPORT_v1.schema.json",
  "title": "TERM_CHAIN_REPORT_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "status", "source_pointer", "term_count", "unknown_segment_total", "rows"],
  "properties": {
    "schema": {
      "const": "TERM_CHAIN_REPORT_v1"
    },
    "status": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "source_pointer": {
      "type": "string"
    },
    "term_count": {
      "type": "integer",
      "minimum": 0
    },
    "unknown_segment_total": {
      "type": "integer",
      "minimum": 0
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["literal", "normalized_literal", "segments", "segment_count", "unknown_segments", "source_pointer"],
        "properties": {
          "literal": {"type": "string"},
          "normalized_literal": {"type": "string"},
          "segments": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["segment", "status"],
              "properties": {
                "segment": {"type": "string"},
                "status": {"type": "string"}
              }
            }
          },
          "segment_count": {"type": "integer", "minimum": 0},
          "unknown_segments": {
            "type": "array",
            "items": {"type": "string"}
          },
          "source_pointer": {"type": "string"}
        }
      }
    }
  }
}
