    },
    "clifford": {
      "tried": true,
      "used": true,
      "reason": "Load-bearing: models AB vs AC entanglement seams as Cl(3) bivectors; e13 component (AB plane), e12 component (AC plane); identifies the geometric midpoint relay where |e12| = |e13|; confirms geometric midpoint is \u22480.526, \u22480.21 units before the entropy flip."
    },
    "geomstats": {
      "tried": true,
      "used": true,
      "reason": "Load-bearing: computes SPD geodesics for rho_C (1-qubit, 2x2 SPD) and rho_AC (2-qubit, 4x4 SPD) across the relay sweep; measures geodesic speed (Riemannian distance between successive states) to detect curvature anomaly (acceleration in geodesic speed) at the flip point; tests whether anomaly appears in rho_C but not rho_AC."
    },
