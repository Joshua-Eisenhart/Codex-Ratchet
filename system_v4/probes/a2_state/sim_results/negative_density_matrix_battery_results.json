  "03_wrong_trace": {
    "test": "03_wrong_trace",
    "finding": "Entropy computed on unnormalized rho is systematically wrong.  Error grows with deviation from trace=1.  Maximally mixed state should give S=1 bit; trace=2 gives S=2 bits.",
    "cases": [
      {
        "trace": 0.5,
        "eigenvalues": [
          0.25,
          0.25
        ],
        "entropy_raw": 1.0,
        "entropy_correct_normalized": 1.0,
        "error_bits": 0.0,
        "relative_error": 0.0
      },
      {
        "trace": 2.0,
        "eigenvalues": [
          1.0,
          1.0
        ],
        "entropy_raw": -0.0,
        "entropy_correct_normalized": 1.0,
        "error_bits": 1.0,
        "relative_error": 1.0
      },
      {
        "trace": 0.01,
        "eigenvalues": [
          0.005,
          0.005
        ],
        "entropy_raw": 0.07643856189774724,
        "entropy_correct_normalized": 1.0,
        "error_bits": 0.9235614381022528,
        "relative_error": 0.9235614381022528
      },
      {
        "trace": 100.0,
        "eigenvalues": [
          50.0,
          50.0
        ],
        "entropy_raw": -564.3856189774724,
        "entropy_correct_normalized": 1.0,
        "error_bits": 565.3856189774724,
        "relative_error": 565.3856189774724
      }
    ]
  },
  "04_rank_deficiency": {
    "test": "04_rank_deficiency",
    "finding": "Pure states have zero eigenvalues.  logm() of singular matrix returns -inf on diagonal (no crash in scipy but result is -inf).  Our clipped entropy handles it; raw logm does not.",
    "cases": [
      {
        "label": "rhoA_product",
        "eigenvalues": [
          0.0,
          1.0
        ],
        "has_zero_eigenvalue": true,
        "entropy": -0.0,
        "entropy_error": null,
        "logm_error": null
      },
      {
        "label": "rhoB_product",
        "eigenvalues": [
          0.0,
          1.0
        ],
        "has_zero_eigenvalue": true,
        "entropy": -0.0,
        "entropy_error": null,
        "logm_error": null
      },
      {
        "label": "rhoA_Bell",
        "eigenvalues": [
          0.4999999999999999,
          0.4999999999999999
        ],
        "has_zero_eigenvalue": false,
        "entropy": 1.0,
        "entropy_error": null,
        "logm_error": null
      },
      {
        "label": "zero_matrix",
        "eigenvalues": [
          0.0,
          0.0
        ],
        "has_zero_eigenvalue": true,
        "entropy": 0.0,
        "entropy_error": null,
        "logm_error": null
      }
    ]
  },
