  "06_dimension_mismatch": {
    "test": "06_dimension_mismatch",
    "finding": "Partial trace, concurrence, negativity all crash on wrong dimensions.  Entropy does NOT crash -- it happily computes on any square matrix.  No dimension guards exist in the standard implementations.",
    "results": {
      "partial_trace_on_3x3": {
        "error": "ValueError: cannot reshape array of size 9 into shape (2,2,2,2)",
        "verdict": "CRASHES"
      },
      "concurrence_on_3x3": {
        "error": "ValueError: matmul: Input operand 1 has a mismatch in its core dimension 0, with gufunc signature (n?,k),(k,m?)->(n?,m?) (size 3 is different from 4)",
        "verdict": "CRASHES"
      },
      "negativity_on_3x3": {
        "error": "ValueError: cannot reshape array of size 9 into shape (2,2,2,2)",
        "verdict": "CRASHES"
      },
      "entropy_on_3x3": {
        "value": 1.448209935368905,
        "error": null,
        "verdict": "COMPUTES (no dimension guard)"
      },
      "sy_kron_sy_times_3x3": {
        "error": "ValueError: matmul: Input operand 1 has a mismatch in its core dimension 0, with gufunc signature (n?,k),(k,m?)->(n?,m?) (size 3 is different from 4)",
        "verdict": "CRASHES"
      }
    }
  },
  "07_near_singular": {
    "test": "07_near_singular",
    "finding": "Von Neumann entropy approaches 0 smoothly for near-pure states.  Renyi-inf tracks it.  Relative entropy to maximally mixed diverges as state approaches pure (D(|0><0| || I/2) = 1 bit, finite).  The real danger is logm() of a matrix with near-zero eigenvalue: produces -inf entries, but trace formula still works via eigendecomposition.",
    "cases": [
      {
        "eigenvalue_ratio": 1e-05,
        "eigenvalues": [
          0.9999900000999989,
          9.99990000099999e-06
        ],
        "von_neumann_bits": 0.00018052162207163008,
        "renyi_2_bits": 2.8853612279867367e-05,
        "renyi_inf_bits": 1.4426878274699924e-05,
        "relative_entropy_to_maxmix": 0.9998194783779284,
        "relative_entropy_error": null,
        "purity": 0.9999800003999939
      },
      {
        "eigenvalue_ratio": 1e-10,
        "eigenvalues": [
          0.9999999999,
          9.999999999e-11
        ],
        "von_neumann_bits": 3.4661976105881914e-09,
        "renyi_2_bits": 2.8853903208047116e-10,
        "renyi_inf_bits": 1.442695160330221e-10,
        "relative_entropy_to_maxmix": 0.9999999965338023,
        "relative_entropy_error": null,
        "purity": 0.9999999998
      },
      {
        "eigenvalue_ratio": 1e-15,
        "eigenvalues": [
          0.9999999999999989,
          9.999999999999989e-16
        ],
        "von_neumann_bits": 1.601713251907458e-15,
        "renyi_2_bits": 3.2034265038149214e-15,
        "renyi_inf_bits": 1.6017132519074597e-15,
        "relative_entropy_to_maxmix": 0.9999999999999484,
        "relative_entropy_error": null,
        "purity": 0.9999999999999978
      },
      {
        "eigenvalue_ratio": 1e-20,
        "eigenvalues": [
          1.0,
          1e-20
        ],
        "von_neumann_bits": -0.0,
        "renyi_2_bits": -0.0,
        "renyi_inf_bits": -0.0,
        "relative_entropy_to_maxmix": 1.0,
        "relative_entropy_error": null,
        "purity": 1.0
      }
    ]
  },
  "08_non_cp_map": {
    "test": "08_non_cp_map",
    "finding": "Partial transpose of entangled states produces negative eigenvalues (Peres-Horodecki criterion).  For Werner states, entanglement detected when p > 1/3.  The output is Hermitian and trace-1 but NOT PSD -- it is not a physical state.  Entropy of the PT output is meaningless.",
    "cases": [
      {
        "werner_p": 1.0,
        "eigenvalues_original": [
          0.0,
          0.0,
          0.0,
          0.9999999999999998
        ],
        "eigenvalues_after_PT": [
          -0.4999999999999999,
          0.4999999999999999,
          0.4999999999999999,
          0.4999999999999999
        ],
        "min_eigenvalue_after_PT": -0.4999999999999999,
        "is_PSD_after_PT": false,
        "trace_preserved": true,
        "entropy_of_PT_output": 1.0,
        "ENTANGLED_DETECTED": true
      },
      {
        "werner_p": 0.5,
        "eigenvalues_original": [
          0.125,
          0.125,
          0.125,
          0.6249999999999999
        ],
        "eigenvalues_after_PT": [
          -0.12499999999999996,
          0.37499999999999994,
          0.37499999999999994,
          0.37499999999999994
        ],
        "min_eigenvalue_after_PT": -0.12499999999999996,
        "is_PSD_after_PT": false,
        "trace_preserved": true,
        "entropy_of_PT_output": 1.2169171866886992,
        "ENTANGLED_DETECTED": true
      },
      {
        "werner_p": 0.3333333333333333,
        "eigenvalues_original": [
          0.16666666666666669,
          0.16666666666666669,
          0.16666666666666669,
          0.49999999999999994
        ],
        "eigenvalues_after_PT": [
          6.013708050052932e-17,
          0.3333333333333333,
          0.3333333333333333,
          0.3333333333333333
        ],
        "min_eigenvalue_after_PT": 6.013708050052932e-17,
        "is_PSD_after_PT": true,
        "trace_preserved": true,
        "entropy_of_PT_output": 1.584962500721156,
        "ENTANGLED_DETECTED": false
      },
      {
        "werner_p": 0.1,
        "eigenvalues_original": [
          0.22499999999999992,
          0.225,
          0.22500000000000003,
          0.32499999999999996
        ],
        "eigenvalues_after_PT": [
          0.175,
          0.275,
          0.275,
          0.275
        ],
        "min_eigenvalue_after_PT": 0.175,
        "is_PSD_after_PT": true,
        "trace_preserved": true,
        "entropy_of_PT_output": 1.9766098981515112,
        "ENTANGLED_DETECTED": false
      },
      {
