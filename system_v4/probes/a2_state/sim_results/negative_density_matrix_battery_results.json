{
  "01_non_hermitian": {
    "test": "01_non_hermitian",
    "pass": true,
    "finding": "eigvalsh silently returns real values for non-Hermitian input; no exception raised.  Entropy silently computes a WRONG number.",
    "cases": [
      {
        "name": "upper_triangular",
        "trace": 1.0,
        "is_hermitian": false,
        "eigenvalues_full": [
          "(0.5+0j)",
          "(0.5+0j)"
        ],
        "has_complex_eigenvalues": false,
        "eigvalsh_forced": [
          0.5,
          0.5
        ],
        "entropy_safe": 1.0,
        "entropy_safe_error": null,
        "entropy_raw": 1.0,
        "entropy_raw_error": null,
        "VERDICT": "BROKEN: eigvalsh silently forces real eigenvalues on non-Hermitian input"
      },
      {
        "name": "asymmetric_real",
        "trace": 1.0,
        "is_hermitian": false,
        "eigenvalues_full": [
          "(0.8316624790355399+2.7369110631344083e-48j)",
          "(0.16833752096445997-1.861893335348152e-48j)"
        ],
        "has_complex_eigenvalues": false,
        "eigvalsh_forced": [
          -0.009901951359278486,
          1.0099019513592786
        ],
        "entropy_safe": -0.014355990968404663,
        "entropy_safe_error": null,
        "entropy_raw": -0.08028389033766152,
        "entropy_raw_error": null,
        "VERDICT": "BROKEN: eigvalsh silently forces real eigenvalues on non-Hermitian input"
      },
      {
        "name": "complex_asymmetric",
        "trace": 1.0,
        "is_hermitian": false,
        "eigenvalues_full": [
          "(0.7058171027271489+0.04858682717566455j)",
          "(0.29418289727285074-0.048586827175664614j)"
        ],
        "has_complex_eigenvalues": true,
        "eigvalsh_forced": [
          0.35857864376269044,
          0.6414213562373096
        ],
        "entropy_safe": 0.9414970282165344,
        "entropy_safe_error": null,
        "entropy_raw": 0.9414970282165344,
        "entropy_raw_error": null,
        "VERDICT": "BROKEN: eigvalsh silently forces real eigenvalues on non-Hermitian input"
      }
    ]
  },
