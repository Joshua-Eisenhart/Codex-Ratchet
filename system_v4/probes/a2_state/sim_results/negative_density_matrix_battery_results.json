        "eigenvalues_original": [
          0.25,
          0.25,
          0.25,
          0.25
        ],
        "eigenvalues_after_PT": [
          0.25,
          0.25,
          0.25,
          0.25
        ],
        "min_eigenvalue_after_PT": 0.25,
        "is_PSD_after_PT": true,
        "trace_preserved": true,
        "entropy_of_PT_output": 2.0,
        "ENTANGLED_DETECTED": false
      }
    ]
  },
  "09_z3_proof": {
    "test": "09_z3_proof",
    "statement": "No 2x2 real symmetric matrix with Tr=1 and det>=0 (PSD) can have a negative eigenvalue.",
    "discriminant_approach": "unsat",
    "eigenvalue_approach": "unsat",
    "proven": true,
    "finding": "z3 confirms UNSAT for both formulations.  The density matrix axioms (Hermitian + PSD + Tr=1) algebraically exclude negative eigenvalues.  This is a CONSTRUCTIVE proof: the constraints force det >= 0 and trace = 1, which together bound the smaller eigenvalue to [0, 1/2]."
  },
  "10_concurrence_non_psd": {
    "test": "10_concurrence_non_psd",
    "finding": "Concurrence computes WITHOUT error on non-PSD input.  sqrtm of a non-PSD matrix returns complex values silently.  The Wootters formula gives a NUMBER that looks plausible but is physically meaningless.  No guard rail whatsoever.",
    "cases": [
      {
        "name": "valid_bell",
        "is_hermitian": true,
        "is_PSD": true,
        "eigenvalues": [
          0.0,
          0.0,
          0.0,
          1.0
        ],
        "concurrence": 0.9999999937348345,
        "concurrence_error": null,
        "negativity": 0.5,
        "negativity_error": null,
        "VERDICT": "VALID"
      },
      {
        "name": "small_negative_push",
        "is_hermitian": true,
        "is_PSD": false,
        "eigenvalues": [
          -0.010204081632653073,
          -0.010204081632653064,
          0.0,
          1.0204081632653061
        ],
        "concurrence": 0.9999999999999993,
        "concurrence_error": null,
        "negativity": 0.5204081632653061,
        "negativity_error": null,
        "VERDICT": "GARBAGE_OUT"
      },
      {
        "name": "large_negative_push",
        "is_hermitian": true,
        "is_PSD": false,
        "eigenvalues": [
          -0.5,
          -0.5,
          0.0,
          0.9999999999999998
        ],
        "concurrence": 0.0,
        "concurrence_error": null,
        "negativity": 0.9999999999999999,
        "negativity_error": null,
        "VERDICT": "GARBAGE_OUT"
      },
      {
        "name": "off_diagonal_asymmetry",
        "is_hermitian": false,
        "is_PSD": true,
        "eigenvalues": [
          0.0,
          0.0,
          0.0,
          1.0
        ],
        "concurrence": 0.9999999937348345,
        "concurrence_error": null,
        "negativity": 0.5049998762467829,
        "negativity_error": null,
        "VERDICT": "GARBAGE_OUT"
      }
    ]
  },
  "11_mixed_pathologies": {
    "test": "11_mixed_pathologies",
    "finding": "Both failures compound.  eigvalsh still returns real values.  Entropy computes a number.  Trace != 1 shifts it.  Non-Hermitian makes eigenvalues unreliable.  NOTHING raises an exception.",
    "checks": {
      "trace": 1.2,
      "trace_is_1": false,
      "is_hermitian": false,
      "eigenvalues_full": [
        "(0.22583426132260603+0j)",
        "(0.9741657386773942+0j)"
      ],
      "eigenvalues_forced_real": [
        0.28377223398316204,
        0.916227766016838
      ],
      "has_complex_eigenvalues": false,
      "entropy": 0.6313173162910047,
      "entropy_error": null,
      "purity": 1.0
    }
  },
  "12_anti_unitary": {
    "test": "12_anti_unitary",
    "finding": "Complex conjugation maps valid states to valid states but is anti-linear (T(alpha*rho) = alpha* * T(rho)).  This violates the linearity axiom of quantum channels.  It cannot be written as sum_k A_k rho A_k^dag.  On 2-qubit states, applying T to one subsystem is related to partial transpose (the non-CP map from test 8).",
    "cases": [
      {
        "name": "real_state_X+",
        "valid_before": "True",
        "valid_after": "True",
        "output_equals_input": true,
        "is_linear_map": false,
        "finding": "Map preserves validity but is ANTI-LINEAR, not linear.  Cannot be represented as a Kraus channel."
      },
      {
        "name": "complex_state_Y+",
        "valid_before": "True",
        "valid_after": "True",
        "output_equals_input": false,
        "is_linear_map": false,
        "finding": "Map preserves validity but is ANTI-LINEAR, not linear.  Cannot be represented as a Kraus channel."
      }
    ]
  },
