        "eigenvalue": "p/2",
        "condition": "0 <= p"
      },
      {
        "eigenvalue": "2 - 3*p/2",
        "condition": "p <= 4/3"
      }
    ],
    "reduction_choi_closed_form": "I - 2|Phi+><Phi+|",
    "reduction_choi_eigenvalues": {
